/* ==========================================
   .editorconfig - Configuration d'éditeur
   ========================================== */

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,css,html,json,md}]
indent_size = 2

[*.{java,py}]
indent_size = 4

[Makefile]
indent_style = tab

[{*.json,.babelrc,.eslintrc}]
indent_size = 2

